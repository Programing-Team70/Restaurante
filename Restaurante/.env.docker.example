# Copia este archivo a .env.docker y completa los valores reales:

# --- BASE DE DATOS PG ---
POSTGRES_USER=Restaurant
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=restaurant_users
POSTGRES_PORT=5436

# --- BASE DE DATOS MONGO ---
MONGODB_PORT=27020
MONGO_DB_NAME=heaven-flavor

# --- PUERTOS EN USO DE SERVICIOS ---
AUTH_SERVICE_PORT=5210
RESTAURANT_SERVICE_PORT=3021
RESERVATIONS_SERVICE_PORT=3023
EVENT_SERVICE_PORT=3022
REPORT_SERVICE_PORT=3024
RESTAURANT_VIEW_PORT=5173
RESTAURANT_APP_METRO_PORT=8081
RESTAURANT_APP_EXPO_PORT=19000
RESTAURANT_APP_EXPO_DEVTOOLS_PORT=19001
RESTAURANT_APP_EXPO_INSPECTOR_PORT=19002

# --- CONFIGURACIONES JWT (deben coincidir en todos los servicios) ---
JWT_SECRET=change-me-jwt-secret-min-256-bits
JWT_ISSUER=HeavenFlavor
JWT_AUDIENCE=HeavenFlavor

# --- URLS INTERNAS DOCKER (comunicacion entre contenedores) ---
AUTH_SERVICE_URL=http://auth-service:5210/res/auth

# --- CONFIGURACIONES FRONTEND URLS (acceso desde el host) ---
FRONTEND_URL=http://localhost:5173
VITE_RESTAURANT_URL=http://localhost:3021/heaven-flavor/rest
VITE_RESERVATION_URL=http://localhost:3023/heaven-flavor/reser
VITE_EVENT_URL=http://localhost:3022/heaven-flavor/even
VITE_REPORT_URL=http://localhost:3024/heaven-flavor/even
VITE_AUTH_URL=http://localhost:5210/res/auth
# --- Expo: 10.0.2.2 - emulador Android
EXPO_PUBLIC_RESTAURANT_URL=http://10.0.2.2:3021/heaven-flavor/rest
EXPO_PUBLIC_RESERVATION_URL=http://10.0.2.2:3023/heaven-flavor/reser
EXPO_PUBLIC_EVENT_URL=http://10.0.2.2:3022/heaven-flavor/even
EXPO_PUBLIC_REPORT_URL=http://10.0.2.2:3024/heaven-flavor/even
EXPO_PUBLIC_AUTH_URL=http://10.0.2.2:5210/res/auth
EXPO_PACKAGER_HOSTNAME=10.0.2.2

# --- CLOUDINARY ---
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_BASE_FOLDER=https://res.cloudinary.com/dsbibfrfc/image/upload/Heaven_flavor
CLOUDINARY_DEFAULT_AVATAR_NAME=restaurant_uur74f.jpg

# --- SMTP (auth-node y auth-service) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_ENABLE_SSL=true
SMTP_USE_IMPLICIT_SSL=true
SMTP_USERNAME=email@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=email@example.com
SMTP_FROM_NAME=Heaven Flavor Support