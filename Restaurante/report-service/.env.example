# Copia a .env: cp .env.example .env

# Server Configuration
PORT=3024

# MongoDB (compartida con server-admin)
# Local standalone: mongodb://localhost:27017/heaven-flavor
# Stack Docker desde el host: mongodb://localhost:27020/heaven-flavor
URI_MONGODB=mongodb://localhost:27017/heaven-flavor

#Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_BASE_FOLDER=https://res.cloudinary.com/your-cloud-name/image/upload/Heaven_flavor
CLOUDINARY_DEFAULT_AVATAR_NAME=your-default-avatar

NODE_TLS_REJECT_UNAUTHORIZED=0