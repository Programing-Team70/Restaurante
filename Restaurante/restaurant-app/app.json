{
  "expo": {
    "name": "restaurant-app",
    "slug": "restaurant-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app-icon.jpeg",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a192f"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon.jpeg",
        "backgroundColor": "#0a192f"
      },
      "package": "com.heavenflavor.restaurantapp"
    },
    "web": {
      "favicon": "./assets/app-icon.jpeg"
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
